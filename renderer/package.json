{
  "name": "ai-ugc-renderer",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Optional React/Playwright + Remotion rendering layer for the ai-ugc-pipeline. Turns approved post JSON into deterministic 1080x1350 carousel PNGs and 1080x1920 Reel MP4s. Runs on Bun.",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview --port 4317 --strictPort",
    "new": "bun scripts/new-post.ts",
    "draft": "bun scripts/draft.mjs",
    "draft-week": "bun scripts/draft-week.mjs",
    "draft-context": "bun scripts/draft-reference.mjs",
    "validate": "bun scripts/validate.ts",
    "export": "tsx scripts/export-carousel.ts",
    "package": "bun scripts/build-package.ts",
    "reel": "bun scripts/render-reel.ts",
    "voice": "bun scripts/voice.mjs",
    "align": "bun scripts/align.mjs",
    "art": "bun scripts/art-comfyui.mjs",
    "art:diffusers": "bun scripts/art.mjs",
    "import-bg": "bun scripts/import-bg.mjs",
    "free-comfyui": "bun scripts/free-comfyui.mjs",
    "pipeline": "bun scripts/pipeline.mjs",
    "typecheck": "tsc --noEmit && tsc --noEmit -p remotion/tsconfig.json",
    "remotion:studio": "bunx remotion studio remotion/index.ts"
  },
  "dependencies": {
    "@fontsource/archivo": "^5.2.5",
    "@fontsource/inter": "^5.2.5",
    "@fontsource/jetbrains-mono": "^5.2.5",
    "@remotion/cli": "^4.0.400",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "remotion": "^4.0.400",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@types/node": "^24.5.2",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^5.0.4",
    "tailwindcss": "^4.1.13",
    "@tailwindcss/vite": "^4.1.13",
    "typescript": "^5.9.2",
    "tsx": "^4.20.6",
    "vite": "^7.1.7",
    "playwright": "^1.56.0"
  }
}

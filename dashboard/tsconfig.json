{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": true,
    "allowJs": true,
    "noEmit": true,
    "types": ["bun-types"],
    "paths": { "@shared/*": ["./shared/*"] },
    "baseUrl": "."
  },
  "include": ["src", "server", "shared", "e2e", "scripts"],
  "//": "src/design is vendored from the chron0s DS (upstream source of truth, React 18-era .d.ts). Its .jsx primitives run fine; exclude from our strict typecheck rather than edit upstream files.",
  "exclude": ["node_modules", "src/design"]
}

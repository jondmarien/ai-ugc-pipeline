{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": true,
    "allowJs": true,
    "noEmit": true,
    "types": ["bun-types"],
    "paths": { "@shared/*": ["./shared/*"] },
    "baseUrl": "."
  },
  "include": ["src", "server", "shared", "e2e", "scripts"]
}

{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/primitives/**",
              "components/slide/**",
              "ui_kits/carousel/**",
              "ui_kits/reel/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Archivo|Inter|JetBrains Mono))/i]",
        "message": "Font not provided by the design system. Available: Archivo, Inter, JetBrains Mono."
      },
      {
        "selector": "JSXOpeningElement[name.name='BrandMark'] > JSXAttribute > JSXIdentifier[name!=/^(?:handle|style|key|ref|className|style|children)$/]",
        "message": "<BrandMark> doesn't accept that prop. Declared props: handle, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Chip'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|variant|accent|style|key|ref|className|style|children)$/]",
        "message": "<Chip> doesn't accept that prop. Declared props: children, variant, accent, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Chip'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:solid|outline)$/]",
        "message": "<Chip> variant must be one of 'solid' | 'outline'."
      },
      {
        "selector": "JSXOpeningElement[name.name='ClaimTag'] > JSXAttribute > JSXIdentifier[name!=/^(?:tag|children|style|key|ref|className|style|children)$/]",
        "message": "<ClaimTag> doesn't accept that prop. Declared props: tag, children, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='ClaimTag'] > JSXAttribute[name.name='tag'] > Literal[value!=/^(?:verified|emerging|scenario)$/]",
        "message": "<ClaimTag> tag must be one of 'verified' | 'emerging' | 'scenario'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Headline'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|size|accent|glow|danger|as|style|key|ref|className|style|children)$/]",
        "message": "<Headline> doesn't accept that prop. Declared props: children, size, accent, glow, danger, as, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Kicker'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|accent|rule|style|key|ref|className|style|children)$/]",
        "message": "<Kicker> doesn't accept that prop. Declared props: children, accent, rule, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Pagination'] > JSXAttribute > JSXIdentifier[name!=/^(?:current|total|accent|style|key|ref|className|style|children)$/]",
        "message": "<Pagination> doesn't accept that prop. Declared props: current, total, accent, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='SlideBackground'] > JSXAttribute > JSXIdentifier[name!=/^(?:src|accent|children|key|ref|className|style|children)$/]",
        "message": "<SlideBackground> doesn't accept that prop. Declared props: src, accent, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='SlideShell'] > JSXAttribute > JSXIdentifier[name!=/^(?:background|accent|handle|current|total|align|format|scale|plate|children|style|key|ref|className|style|children)$/]",
        "message": "<SlideShell> doesn't accept that prop. Declared props: background, accent, handle, current, total, align, format, scale, plate, children, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='SlideShell'] > JSXAttribute[name.name='align'] > Literal[value!=/^(?:start|center|end)$/]",
        "message": "<SlideShell> align must be one of 'start' | 'center' | 'end'."
      },
      {
        "selector": "JSXOpeningElement[name.name='SlideShell'] > JSXAttribute[name.name='format'] > Literal[value!=/^(?:carousel|reel)$/]",
        "message": "<SlideShell> format must be one of 'carousel' | 'reel'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Subline'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|style|key|ref|className|style|children)$/]",
        "message": "<Subline> doesn't accept that prop. Declared props: children, style."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
